# Backend Environment Variables Template (dev)

# Runtime
PORT=4000
HOST=0.0.0.0
HTTPS_ENABLED=false

# Database
POSTGRES_USER=secureapp
POSTGRES_PASSWORD=secureapp_dev_password
POSTGRES_DB=secureapp
# Backend local + DB Docker Compose (host mapped to 5433):
DATABASE_URL=postgresql://secureapp:secureapp_dev_password@localhost:5433/secureapp
# Local Postgres (outside Docker) alternative:
# DATABASE_URL=postgresql://secureapp:secureapp_dev_password@localhost:5432/secureapp
# Backend in Docker Compose alternative:
# DATABASE_URL=postgresql://secureapp:secureapp_dev_password@db:5432/secureapp

# HTTPS (only if HTTPS_ENABLED=true)
CERTS_DIR=/app/certs
HTTPS_CERT_PATH=/app/certs/prodpol.pem
HTTPS_KEY_PATH=/app/certs/prodpol-key.pem

# Frontend linkage (surtout utile pour un client web / liens emails)
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,https://localhost:5173,http://localhost:3000,https://localhost:3000,http://localhost:8080,https://localhost:8080

# JWT Configuration (generate a new secret with: openssl rand -hex 64)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=15m
REFRESH_EXPIRATION=7d

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Admin Account
ADMIN_EMAIL=admin@secureapp.com
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_admin_password_here
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=System
ADMIN_AVATAR_URL=https://i.pravatar.cc/150?img=3
ADMIN_PHONE=+1234567890
